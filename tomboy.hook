local function getfile(name)
    local repo = "https://raw.githubusercontent.com/SWIMHUBISWIMMING/swimhub/main/"
    local success, content = pcall(request, {Url = repo..name, Method = "GET"})
    if success then
        if content.StatusCode == 200 then
            return content.Body
        else
            return print("getfile returned error code: " .. tostring(content.StatusCode))
        end
    else
        return print("getfile pcall error: " .. tostring(content))
    end
end
local function isTomboyHookfile(file)
    return isfile("Tomboy.hook/new/files/"..file)
end
local function readTomboyHookfile(file)
    if not isTomboyHookfile(file) then return false end
    local success, returns = pcall(readfile, "Tomboy.hook/new/files/"..file)
    if success then return returns else return print(returns) end
end
local function loadTomboyHookfile(file)
    if not isTomboyHookfile(file) then return false end
    local success, returns = pcall(loadstring, readTomboyHookfile(file))
    if success then return returns else return print(returns) end
end
local function getTomboyHookasset(file)
    if isTomboyHookfile(file) then return false end
    local success, returns = pcall(getcustomasset, "Tomboy.hook/new/files/"..file)
    if success then return returns else return print(returns) end
end
do
    if not isfolder("Tomboy.hook") then makefolder("Tomboy.hook") end
    if not isfolder("Tomboy.hook/new") then makefolder("Tomboy.hook/new") end
    if not isfolder("Tomboy.hook/new/files") then makefolder("Tomboy.hook/new/files") end
    local function getfiles(force, list)
        for _, file in list do
            if (force or not force and not isTomboyHookfile(file)) then
                writefile("Tomboy.hook/new/files/"..file, getfile(file))
            end
        end
    end
    local gotassets = getfile("assets.json")
    if not gotassets then return end
    local assets = HttpService:JSONDecode(gotassets)
    local localassets = readTomboyHookfile("assets.json")
    if localassets then
        localassets = HttpService:JSONDecode(localassets)
        if localassets.version ~= assets.version then
            writefile("Tomboy.hook/new/files/assets.json", gotassets)
            getfiles(true, assets.list)
        end
    else
        writefile("Tomboy.hook/new/files/assets.json", gotassets)
    end
    getfiles(false, assets.list)
end
