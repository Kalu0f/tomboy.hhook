    })
    local tipanel = {}
    tipanel.pos = _Vector2new(20, 350)
    tipanel.width = 250
    tipanel.height = 100
    tipanel.dragging = false
    tipanel.dragoffset = Vector2.zero
    local avatar_cache = {}
    tipanel.bg = cheat.utility.new_drawing("Square", {
        Visible = false, Filled = true,
