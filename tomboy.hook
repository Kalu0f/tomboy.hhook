local tipanel_settings = {
    bgcolor = Color3.fromRGB(15, 15, 15),
    bordercolor = Color3.fromRGB(45, 45, 45),
    accentcolor = Color3.fromRGB(155, 60, 220),
    glowcolor = Color3.fromRGB(155, 60, 220),
